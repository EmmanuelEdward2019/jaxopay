# Server Configuration
NODE_ENV=development
PORT=3000
API_VERSION=v1

# Database Configuration (PostgreSQL via Supabase)
DATABASE_URL=postgresql://user:password@host:5432/database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=jaxopay
DB_USER=postgres
DB_PASSWORD=your_password
DB_SSL=true
# Optional: pool size for remote Supabase (default 15 when host looks like supabase/pooler)
# DB_POOL_MAX=15
# Optional: Postgres statement_timeout in ms per pooled connection (default 25000)
# DB_STATEMENT_TIMEOUT_MS=25000

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Encryption
ENCRYPTION_KEY=your-32-character-encryption-key-here

# CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:5173,https://jaxopay.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Twilio (SMS/OTP)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# SendGrid (Email)
SENDGRID_API_KEY=your_sendgrid_api_key
FROM_EMAIL=noreply@jaxopay.com
FROM_NAME=JAXOPAY

# OAuth Providers
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
FACEBOOK_CALLBACK_URL=http://localhost:3000/api/v1/auth/facebook/callback

# Payment Providers
FLUTTERWAVE_PUBLIC_KEY=your_flutterwave_public_key
FLUTTERWAVE_SECRET_KEY=your_flutterwave_secret_key
FLUTTERWAVE_ENCRYPTION_KEY=your_flutterwave_encryption_key

PAYSTACK_PUBLIC_KEY=your_paystack_public_key
PAYSTACK_SECRET_KEY=your_paystack_secret_key

# Crypto Providers
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret

COINBASE_API_KEY=your_coinbase_api_key
COINBASE_API_SECRET=your_coinbase_api_secret

# Quidax (Primary Crypto & Exchange)
QUIDAX_SECRET_KEY=your_quidax_secret_key
QUIDAX_PUBLIC_KEY=your_quidax_public_key
QUIDAX_BASE_URL=https://api.quidax.com/v1

# Card Issuance
SUDO_API_KEY=your_sudo_api_key
SUDO_API_SECRET=your_sudo_api_secret

# Flight Booking
AMADEUS_API_KEY=your_amadeus_api_key
AMADEUS_API_SECRET=your_amadeus_api_secret

# Graph Finance
GRAPH_API_KEY=your_graph_api_key
GRAPH_BASE_URL=https://api.usegraph.com

# Korapay
KORAPAY_PUBLIC_KEY=your_korapay_public_key
KORAPAY_SECRET_KEY=your_korapay_secret_key
# Override to toggle sandbox/live URL (default: https://api.korapay.com/merchant/api/v1)
KORAPAY_BASE_URL=https://api.korapay.com/merchant/api/v1

# VTPass (optional — bill routes use Strowallet by default)
VTPASS_PUBLIC_KEY=your_vtpass_public_key
VTPASS_SECRET_KEY=your_vtpass_secret_key
VTPASS_API_KEY=your_vtpass_api_key
# Set to true to use VTpass for /bills/providers, /bills/validate, /bills/pay again
# VTPASS_BILLS_ENABLED=true
# Override to force sandbox: https://sandbox.vtpass.com/api (auto-set by NODE_ENV)
# VTPASS_BASE_URL=https://sandbox.vtpass.com/api

# Strowallet (Virtual cards — primary when both keys set; Graph is fallback)
# Strowallet often requires your API server’s outbound/public IP in their dashboard allow list
# (errors like "untrusted source IP" mean the IP making server-to-server calls is not whitelisted).
STROWALLET_PUBLIC_KEY=your_strowallet_public_key
STROWALLET_SECRET_KEY=your_strowallet_secret_key
STROWALLET_BASE_URL=https://strowallet.com
# Bills: Strowallet (https://strowallet.readme.io) — airtime, data, cable, electricity, education, e-PIN, SME data when keys are set. VTpass is off unless VTPASS_BILLS_ENABLED=true.
# Set to false if Strowallet rejects secret_key in the form body (default: send secret_key).
# STROWALLET_BILLS_SEND_SECRET=false

# Graph Finance (Virtual Cards — fallback if Strowallet fails or keys missing)
GRAPH_API_KEY=your_graph_api_key
GRAPH_BASE_URL=https://api.usegraph.com
GRAPH_WEBHOOK_SECRET=your_graph_webhook_secret

# API Base URL (must be publicly accessible for webhook callbacks in production)
API_BASE_URL=http://localhost:3001

# KYC/AML — Smile Identity (server-only; never use VITE_* or expose in API responses)
# SMILE_ID_API_KEY = HMAC secret from Smile portal (“API Key”) — may match mobile smile_config auth_token
# SMILE_ID_AUTH_TOKEN = optional alias for the same secret
SMILE_ID_API_KEY=your_smile_api_key
SMILE_ID_PARTNER_ID=your_smile_partner_id
SMILE_ID_SANDBOX=false
# Optional: override API host (no /v1 suffix). Defaults: api.smileidentity.com or testapi.smileidentity.com
# SMILE_ID_API_BASE_URL=https://api.smileidentity.com
# Dev only: accept Smile webhooks without signature check
# SMILE_WEBHOOK_SKIP_VERIFY=true
SMILE_IDENTITY_API_KEY=
SMILE_IDENTITY_PARTNER_ID=

# Email (Resend) — auth, receipts, KYC alerts (see src/services/email.service.js)
RESEND_API_KEY=
FRONTEND_URL=http://localhost:5173
# KYC: comma-separated inboxes for compliance (manual submissions, admin decisions, Smile results)
COMPLIANCE_EMAIL=compliance@yourcompany.com
# KYC + transaction alerts; merged with COMPLIANCE_EMAIL (duplicates removed)
ADMIN_EMAIL=admin@yourcompany.com

# Monitoring & Logging
SENTRY_DSN=your_sentry_dsn
LOG_LEVEL=info

# Redis (Session & Caching)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your_redis_password

# Webhook Secrets
FLUTTERWAVE_WEBHOOK_SECRET=your_flutterwave_webhook_secret
PAYSTACK_WEBHOOK_SECRET=your_paystack_webhook_secret

# Reloadly (Gift Cards & Top-ups)
RELOADLY_CLIENT_ID=your_reloadly_client_id
RELOADLY_CLIENT_SECRET=your_reloadly_client_secret
RELOADLY_API_SECRET_KEY=your_reloadly_api_secret_key
RELOADLY_WEBHOOK_SECRET=your_reloadly_webhook_secret
RELOADLY_SANDBOX=false

