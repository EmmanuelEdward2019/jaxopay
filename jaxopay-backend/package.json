{
  "name": "jaxopay-backend",
  "version": "1.0.0",
  "description": "JAXOPAY Backend API Server - Cross-border fintech platform",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "build": "echo 'No build step required for backend'",
    "test": "NODE_ENV=test jest --coverage --detectOpenHandles",
    "test:watch": "NODE_ENV=test jest --watch",
    "test:unit": "NODE_ENV=test jest src/**/__tests__/**/*.test.js",
    "test:integration": "NODE_ENV=test jest tests/integration/**/*.test.js",
    "test:ci": "NODE_ENV=test jest --ci --coverage --maxWorkers=2",
    "lint": "eslint src/**/*.js",
    "migrate": "node src/database/migrate.js",
    "migrate:indices": "psql $DATABASE_URL < migrations/010_add_performance_indices.sql"
  },
  "keywords": [
    "fintech",
    "payments",
    "crypto",
    "api"
  ],
  "author": "JAXOPAY",
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.105.0",
    "axios": "^1.15.2",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "crypto-js": "^4.2.0",
    "decimal.js": "^10.6.0",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-rate-limit": "^7.5.1",
    "express-validator": "^7.3.2",
    "geoip-lite": "^1.4.10",
    "helmet": "^7.2.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "nodemailer": "^8.0.7",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "resend": "^6.12.2",
    "smile-identity-core": "^3.1.0",
    "speakeasy": "^2.0.0",
    "twilio": "^4.23.0",
    "ua-parser-js": "^1.0.41",
    "uuid": "^9.0.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "supertest": "^6.3.4"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
